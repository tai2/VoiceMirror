{
  "name": "voicemirror",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:dev:ios": "npx eas-cli@latest build --profile development --platform ios",
    "build:dev:android": "npx eas-cli@latest build --profile development --platform android",
    "build:preview": "npx eas-cli@latest build --profile preview --platform all",
    "build:preview:ios": "npx eas-cli@latest build --profile preview --platform ios",
    "build:preview:android": "npx eas-cli@latest build --profile preview --platform android",
    "build:prod": "npx eas-cli@latest build --profile production --platform all",
    "device:register": "npx eas-cli@latest device:create"
  },
  "dependencies": {
    "audio-encoder": "file:./modules/audio-encoder",
    "expo": "~55.0.5",
    "expo-dev-client": "^55.0.11",
    "expo-file-system": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-audio-api": "^0.11.7"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
