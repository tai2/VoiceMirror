{
  "expo": {
    "name": "VoiceMirror",
    "slug": "voice-mirror",
    "scheme": "voicemirror",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "locales": {
      "en": "./languages/en.json",
      "ja": "./languages/ja.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.tai2.voicemirror",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "package": "net.tai2.voicemirror",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/images/icon_adaptive.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "eas": {
        "projectId": "8e67ba08-d928-4773-ad24-5452c819b900"
      }
    },
    "plugins": [
      "./plugins/withCleartextTraffic",
      "./plugins/withAsyncStorageLocalRepo",
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "VoiceMirror records your voice so you can immediately hear yourself back.",
          "androidPermissions": ["android.permission.RECORD_AUDIO"]
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": ["en", "ja"]
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "voice-mirror",
          "organization": "tai2net"
        }
      ]
    ]
  }
}
